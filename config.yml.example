endpoints:
  # Unified endpoint (following pitucode recommendation).
  # All platforms now use the single /downloader/aio endpoint.
  # Previously there were per-platform overrides (ttsave for tiktok, igstory, fbdown, etc.),
  # but those dedicated endpoints are no longer required.
  default: https://api.pitucode.com/downloader/aio

  # per_platform: {}   # intentionally removed for simplicity — everything routes through default + process_generic (except YouTube)
